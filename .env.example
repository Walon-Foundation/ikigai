NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
DATABASE_URL=postgresql://...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
CLERK_WEBHOOK_SECRET=whsec_...

# Surface hostnames — validated in lib/env.ts; client values in lib/env.client.ts.
# Include the port for local dev (*.localhost resolves natively, no /etc/hosts needed).
# On Vercel: set these to your deployment domains (no port needed).
# The app's absolute URL is derived from NEXT_PUBLIC_APP_HOSTNAME
# (http for localhost, https otherwise) — there is no separate APP_URL var.
NEXT_PUBLIC_APP_HOSTNAME=app.localhost:3000     # PWA host (server routing + client links)
ADMIN_HOSTNAME=admin.localhost:3000             # admin host (server routing)
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000 # marketing site (cross-subdomain links)

# Payments — leave PAYMENT_PROVIDER unset (or "stub") to use the dev stub.
# Set to "monime" and fill the credentials to take real Monime payments
# (env validation fails at boot if "monime" is set without credentials).
PAYMENT_PROVIDER=stub
MONIME_SPACE_ID=
MONIME_ACCESS_TOKEN=
MONIME_FINANCIAL_ACCOUNT_ID=
