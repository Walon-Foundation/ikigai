NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
DATABASE_URL=postgresql://...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
CLERK_WEBHOOK_SECRET=whsec_...

# Surface hostnames — include port for local dev (*.localhost resolves natively, no /etc/hosts needed)
# On Vercel: set these to your deployment URL or custom domain (no port needed)
APP_HOSTNAME=app.localhost:3000              # server-side: proxy routing + link construction
ADMIN_HOSTNAME=admin.localhost:3000         # server-side: proxy routing
NEXT_PUBLIC_APP_HOSTNAME=app.localhost:3000 # build-time client-side: nav "Install" button
MARKETING_URL=http://localhost:3000         # absolute URL of marketing site (used for cross-subdomain redirects)
